#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

#define BUFFER_SIZE 4096
#define KEY_SIZE 128

void advanced_cipher_engine(const char *input_path, const char *output_path, const char *secret_key, int mode) {
    FILE *src = fopen(input_path, "rb");
    FILE *dest = fopen(output_path, "wb");
    
    if (!src || !dest) {
        printf("[-] Critical Matrix Error: Cannot bind target file vectors. Access Denied.\n");
        if (src) fclose(src);
        if (dest) fclose(dest);
        return;
    }

    // حجز بافر ديناميكي في الـ Heap لتسريع النقل والـ Streaming 100%
    unsigned char *buffer = (unsigned char *)malloc(BUFFER_SIZE);
    if (!buffer) {
        printf("[-] Memory Allocation Failed inside Heap Matrix.\n");
        fclose(src); fclose(dest);
        return;
    }

    size_t key_len = strlen(secret_key);
    
    // حماية إضافية لحالة عدم إدخال مفتاح سري
    if (key_len == 0) {
        printf("[-] Critical Failure: Secret key length is zero. Halting Engine.\n");
        free(buffer); fclose(src); fclose(dest);
        return;
    }

    size_t key_index = 0;
    size_t read_bytes;

    printf("[*] Core Crypto Phase: Executing stream injection... \n");

    while ((read_bytes = fread(buffer, 1, BUFFER_SIZE, src)) > 0) {
        for (size_t i = 0; i < read_bytes; i++) {
            // التكتيك المريgل: الـ Salt يدور بين 0 و 6 لحماية تكرار البايتات
            unsigned char salt_factor = (unsigned char)(key_index % 7);
            
            if (mode == 1) {
                // التشفير: نديرو XOR مع المفتاح أولاً، ثم نزيدو الـ Salt برا
                buffer[i] = (unsigned char)((buffer[i] ^ secret_key[key_index]) + salt_factor);
            } else {
                // فك التشفير: عملية عكسية دقيقة، ننقصو الـ Salt أولاً، ثم نديرو الـ XOR
                buffer[i] = (unsigned char)((buffer[i] - salt_factor) ^ secret_key[key_index]);
            }
            
            key_index = (key_index + 1) % key_len;
        }
        fwrite(buffer, 1, read_bytes, dest);
    }

    free(buffer);
    fclose(src);
    fclose(dest);

    // OpSec الصارمة: تدمير الملف الأصلي كليا بعد التشفير الناجح
    if (mode == 1) {
        printf("[*] OpSec Enforcement: Shredding and purging target source matrix... \n");
        remove(input_path); 
    }

    printf("[+] Operational Crypto Success: Cipher sequence synchronized seamlessly! \n");
}

